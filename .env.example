# =============================================================================
# 웹소설 AI 편집 어시스턴트 — 환경 변수
# =============================================================================
# 사용법:
#   1. 이 파일을 복사해 `.env` 또는 `.env.local` 로 저장
#      cp .env.example .env
#   2. 아래 VITE_ANTHROPIC_API_KEY 에 본인 키 입력
#   3. npm run dev 로 개발 서버 실행
#
# ⚠️  VITE_ 로 시작하는 변수는 빌드 시 클라이언트 번들에 포함됩니다.
#     npm run dev (로컬)에서만 API Key가 사용됩니다. build:pages 배포에는 넣지 마세요.
# =============================================================================

# Claude API Key (Anthropic)
# 발급: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# (선택) GitHub Pages 배포 URL — postbuild/prerender 에 사용
# VITE_SITE_URL=https://kk00701903-hub.github.io/private-novel/
